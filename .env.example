# Local API
TDX_STOCK_API_HOST=127.0.0.1
TDX_STOCK_API_PORT=8765

# SQLite database. Relative paths are resolved from the project root.
TDX_STOCK_DB_PATH=data/local.db

# Data provider selection: mock, eltdx, akshare, tdx_token, tdxquant.
TDX_DATA_PROVIDER=mock

# Keep real tokens out of git.
TDX_API_TOKEN=
TUSHARE_TOKEN=
